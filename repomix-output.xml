.carousel-caption {
  background: rgba(0,0,0,0.45);
  padding: 20px;
  border-radius: 12px;
}

.offer-slider {
  overflow: hidden;
  background: #f8f9fa;
  padding: 20px 0;
}

.offer-track {
  display: flex;
  gap: 20px;
  width: max-content;
  animation: scroll 20s linear infinite;
}

.offer-track img {
  width: 300px;
  height: 250px;
  object-fit: cover;
  border-radius: 15px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.15);
}

@keyframes scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}
